# Delivery Rider — Environment Variables
# Copy this file to .env and fill in the values for local development.
# Do NOT commit your .env file to version control.

# Base URL of the backend API (no trailing slash).
# For local development, point this to your local server, e.g. http://localhost:3000
# For production, use your deployed backend URL.
VITE_API_BASE_URL=https://mediflow-backend-z29j.onrender.com

# ── Demo / Mock mode ──────────────────────────────────────────────────────────
#
# Set to "true" to run the app entirely in the browser without a real backend.
# All API calls are replaced by instant in-memory responses.
#
# Demo credentials when VITE_MOCK=true:
#   Phone : any 10-digit number  (e.g. 0801234567)
#   OTP   : 123456
#
# Set to "false" (or remove the line) to use the real backend API.
VITE_MOCK=true

# ── Build & Deploy Notes ──────────────────────────────────────────────────────
#
# Local development (no backend needed):
#   npm install
#   cp .env.example .env          # VITE_MOCK=true is already set above
#   npm run dev                   # starts at http://localhost:5173/delivery-man/
#
# Local development (with real backend):
#   Set VITE_MOCK=false and VITE_API_BASE_URL to your local server.
#
# Production build:
#   npm run build                 # outputs to dist/
#   npm run preview               # preview the production build locally
#
# GitHub Pages deployment:
#   The app is built with base: '/delivery-man/' (see vite.config.ts).
#   The GitHub Actions workflow (deploy.yml) builds and deploys automatically
#   on every push to main.  Set VITE_API_BASE_URL and VITE_MOCK=false as
#   repository secrets in Settings → Secrets → Actions.
#
# Troubleshooting blank/white page:
#   1. Open browser DevTools → Console and check for errors.
#   2. Verify VITE_API_BASE_URL is reachable from the browser.
#   3. Ensure the repo is served from /delivery-man/ (GitHub Pages project site).
#   4. A global ErrorBoundary will show a human-readable error instead of a
#      blank screen when any JS or network error occurs.
